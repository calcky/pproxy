%%{init: {"theme":"base","themeVariables":{"fontFamily":"Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif","background":"#ffffff","primaryTextColor":"#0f172a","lineColor":"#64748b","clusterBkg":"#ffffff","clusterBorder":"#cbd5e1"},"flowchart":{"curve":"linear","htmlLabels":true,"nodeSpacing":52,"rankSpacing":64,"padding":12}}}%%
%% pproxy 总体架构
%% 这张图只表达高层结构。线程/队列细节见 doc/threads.mmd，端到端时序见 doc/dataflow.mmd。
flowchart LR
    classDef host fill:#f8fafc,stroke:#64748b,color:#0f172a,stroke-width:1.4px;
    classDef ingress fill:#e0f2fe,stroke:#0284c7,color:#075985,stroke-width:1.6px;
    classDef plane fill:#fff7ed,stroke:#f97316,color:#7c2d12,stroke-width:1.8px;
    classDef tunnel fill:#dbeafe,stroke:#2563eb,color:#1e3a8a,stroke-width:1.6px;
    classDef support fill:#f1f5f9,stroke:#94a3b8,color:#334155,stroke-width:1.2px;
    classDef ctrl fill:#f3e8ff,stroke:#9333ea,color:#581c87,stroke-width:1.4px;

    APP["Local apps<br/>Linux kernel stack"]:::host
    LEFT["Left I/O<br/>pp_pkt_io_ops_t<br/><span style='font-size:12px'>tun / raw / af_xdp / netmap / pcap / dpdk</span>"]:::ingress
    DATA["Data plane<br/><span style='font-size:12px'>left_rx -> worker[N] -> right_tx<br/>right_rx -> worker[N] -> left_tx</span>"]:::plane
    TUNNEL["Tunnel layer<br/><span style='font-size:12px'>proto: tcp / udp / icmp<br/>io: kernel_socket / raw / tun / af_xdp<br/>netmap / pcap / dpdk / memif</span>"]:::tunnel
    REMOTE["Remote server"]:::host

    APP ==>|hijack / reinject| LEFT
    LEFT ==>|IP packets| DATA
    DATA ==>|sid + payload| TUNNEL
    TUNNEL ==>|wire| REMOTE

    REMOTE -.->|return path uses same blocks in reverse| TUNNEL

    subgraph SUPPORT["Shared data-plane facilities"]
        direction LR
        RING["SPSC / MPSC rings"]:::support
        MEM["mempool / mbuf"]:::support
        SESS["SessionTable shards"]:::support
        DPI["DPI chain"]:::support
        TIMER["timer wheel"]:::support
    end

    subgraph CONTROL["Control plane"]
        direction LR
        MAIN["main<br/>lifecycle"]:::ctrl
        MGMT["mgmt<br/>unix + /metrics"]:::ctrl
        RELOAD["reload<br/>RCU-style config"]:::ctrl
    end

    DATA -.->|queue / alloc / classify| SUPPORT
    CONTROL -.->|start / stop / observe| DATA
    CONTROL -.->|config snapshot| SUPPORT

    style SUPPORT fill:#f8fafc,stroke:#cbd5e1,stroke-width:1px,color:#334155
    style CONTROL fill:#faf5ff,stroke:#e9d5ff,stroke-width:1px,color:#581c87
