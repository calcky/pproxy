%%{init: {"theme":"base","themeVariables":{"fontFamily":"Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif","background":"#ffffff","primaryTextColor":"#0f172a","lineColor":"#64748b","clusterBkg":"#ffffff","clusterBorder":"#cbd5e1"},"flowchart":{"curve":"linear","htmlLabels":true,"nodeSpacing":46,"rankSpacing":54,"padding":12}}}%%
%% pproxy 线程与队列拓扑
%% 只画线程和 ring 关系；更细的包级顺序见 doc/dataflow.mmd。
flowchart TB
    classDef io fill:#e0f2fe,stroke:#0284c7,color:#075985,stroke-width:1.5px;
    classDef worker fill:#fff7ed,stroke:#f97316,color:#7c2d12,stroke-width:1.8px;
    classDef tx fill:#dbeafe,stroke:#2563eb,color:#1e3a8a,stroke-width:1.5px;
    classDef ctrl fill:#f3e8ff,stroke:#9333ea,color:#581c87,stroke-width:1.3px;
    classDef note fill:#f8fafc,stroke:#cbd5e1,color:#475569,stroke-dasharray:4 3;

    LEFT["left I/O<br/><span style='font-size:12px'>tun / raw / xdp / netmap / pcap / dpdk</span>"]:::io
    LRX["left_rx<br/><span style='font-size:12px'>rx burst<br/>flow hash</span>"]:::worker
    WK["worker[k] × N<br/><span style='font-size:12px'>session shard[k]<br/>DPI + encap/restore</span>"]:::worker
    RTX["right_tx[t] × M<br/><span style='font-size:12px'>tx_ring[t] consumer<br/>proto encode + send</span>"]:::tx
    WIRE["wire / tunnel I/O<br/><span style='font-size:12px'>tcp / udp / icmp × kernel/raw/tun/xdp/netmap/pcap/dpdk/memif</span>"]:::io
    RRX["right_rx[t] × M<br/><span style='font-size:12px'>recv + decode<br/>sid -> shard</span>"]:::tx
    LTX["left_tx<br/><span style='font-size:12px'>left_tx.ring consumer<br/>tx burst</span>"]:::worker

    CTRL["control plane<br/><span style='font-size:12px'>main: lifecycle<br/>timer: ttl / aging<br/>mgmt: stats / sessions / reload</span>"]:::ctrl
    RINGS["ring contracts<br/><span style='font-size:12px'>rx_ring[k]: SPSC<br/>tx_ring[t], back_ring[k], left_tx.ring: MPSC<br/>ctrl_ring[k]: timer/mgmt -> worker</span>"]:::note

    LEFT ==>|rx burst| LRX
    LRX ==>|"rx_ring[k]<br/>SPSC"| WK
    WK ==>|"tx_ring[t]<br/>MPSC"| RTX
    RTX ==>|send| WIRE

    WIRE ==>|recv| RRX
    RRX ==>|"back_ring[k]<br/>MPSC"| WK
    WK ==>|"left_tx.ring<br/>MPSC"| LTX
    LTX ==>|tx burst| LEFT

    CTRL -.->|"start / stop / observe"| LRX
    CTRL -.->|"ttl cleanup<br/>ctrl_ring[k]"| WK
    CTRL -.->|"start / stop / observe"| RTX
    CTRL -.->|"start / stop / observe"| RRX
    CTRL -.->|"start / stop / observe"| LTX
    RINGS -.-> WK
