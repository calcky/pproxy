{
  "log":     { "level": "trace" },
  "runtime": { "workers": 1 },
  "left":    { "kind": "tun", "name": "pp1",
               "tun": { "ifname": "ppclab1", "cidr": "192.168.1.0/24",
                        "mtu": 1500, "no_pi": true } },
  "tunnels": [{
    "name": "srv", "proto": "udp", "io": "dpdk",
    "mode": "server", "listen": "0.0.0.0:19900",
    "udp":  { "mtu": 1500 },
    "io_cfg": {
      "port_id": 0,
      "queue_id": 0,
      "nframes": 2048,
      "eal_args": "pproxy -l 0,1 --proc-type=primary --in-memory"
    }
  }],
  "mgmt":    { "unix_socket": "/opt/pproxy/run/pp.sock",
               "metrics": { "enable": true, "listen": "127.0.0.1:19991" } }
}
