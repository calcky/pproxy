{
  "log":     { "level": "trace" },
  "runtime": { "workers": 1 },
  "left":    { "kind": "tun", "name": "pp1",
               "tun": { "ifname": "ppclab1", "cidr": "192.168.1.0/24",
                        "mtu": 1500, "no_pi": true } },
  "tunnels": [{
    "name": "srv", "proto": "icmp", "io": "raw_socket",
    "mode": "server", "listen": "0.0.0.0:0",
    "icmp": { "identifier_base": 43962, "reply_only": false }
  }],
  "session": { "max_per_shard": 1024 },
  "mgmt":    { "unix_socket": "/opt/pproxy/run/pp.sock",
               "metrics": { "enable": true, "listen": "127.0.0.1:19991" } }
}
