{
  "log":     { "level": "trace" },
  "runtime": { "workers": 1 },
  "left":    { "kind": "tun", "name": "pp1",
               "tun": { "ifname": "ppclab1", "cidr": "192.168.1.0/24",
                        "mtu": 1500, "no_pi": true } },
  "tunnels": [{
    "name": "srv", "proto": "udp", "io": "memif",
    "mode": "server", "listen": "0.0.0.0:19900",
    "udp":  { "mtu": 1500 },
    "io_cfg": {
      "socket_path": "/opt/pproxy/run/memif.sock",
      "interface_id": 0,
      "is_master": false,
      "ring_size": 1024,
      "buffer_size": 2048
    }
  }],
  "mgmt":    { "unix_socket": "/opt/pproxy/run/pp.sock",
               "metrics": { "enable": true, "listen": "127.0.0.1:19991" } }
}
